# Copy to .env before starting the stack: cp .env.example .env

# Django
DJANGO_SECRET_KEY=dev-secret-change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# Database (Docker Compose service hostnames)
DATABASE_URL=postgres://crm:crm@postgres:5432/crm
REDIS_URL=redis://redis:6379/0

# CRM runtime
RESPONSE_SLA_SECONDS=60
PRESENCE_HEARTBEAT_INTERVAL_SECONDS=5
PRESENCE_GRACE_SECONDS=15
MONITOR_REFRESH_SECONDS=5

# CORS and invite links
CORS_ALLOWED_ORIGINS=http://localhost:5173
FRONTEND_BASE_URL=http://localhost:5173

# Frontend (Vite — read from repo root .env or process env in Docker)
VITE_API_BASE_URL=http://localhost:8000/api
VITE_WS_BASE_URL=ws://localhost:8000

# PostgreSQL container
POSTGRES_DB=crm
POSTGRES_USER=crm
POSTGRES_PASSWORD=crm

# Demo activity (in-process background thread; disabled by default)
DEMO_ACTIVITY_ENABLED=0
